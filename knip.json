{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/cli": {
      "entry": ["src/cli.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/routes/**/+{page,layout,server}.{svelte,ts}"],
      "project": ["src/**/*.{ts,svelte}"]
    }
  }
}
